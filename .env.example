# Orbita API — Environment Configuration
# Copy to .env and fill in values for your environment

# App
APP_NAME=Orbita API
DEBUG=true

# Database (PostgreSQL via Railway / Docker)
DATABASE_URL=postgresql+asyncpg://orbita:orbita_secret@localhost:5432/orbita

# Security
SECRET_KEY=generate-a-random-64-character-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI — Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
AI_DAILY_CAP_USD=5.0

# Market Data — SerpAPI
SERPAPI_KEY=...

# S3 / Cloudflare R2 (receipts, uploads)
S3_ENDPOINT=http://localhost:9000         # or https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY=minioadmin                  # or R2 Access Key ID
S3_SECRET_KEY=minioadmin                  # or R2 Secret Access Key
S3_BUCKET=orbita-receipts
S3_REGION=us-east-1

# CORS
CORS_ORIGINS=http://localhost:3000

# Railway
RAILWAY_ENVIRONMENT=development

# Sentry (error tracking)
SENTRY_DSN=
